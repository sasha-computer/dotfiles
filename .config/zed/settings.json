{
  "buffer_font_family": "Berkeley Mono",
  "cli_default_open_behavior": "new_window",
  "soft_wrap": "editor_width",
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "vim": {
    "toggle_relative_line_numbers": false,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "show_edit_predictions": true,
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "zed.dev",
      "model": "gemini-3.5-flash",
      "enable_thinking": true,
      "effort": "MEDIUM"
    },
    "dock": "right",
    "button": true,
    "favorite_models": [],
    "model_parameters": [],
  },
  "collaboration_panel": {
    "button": false,
  },
  "git_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": true,
  },
  "focus_follows_mouse": {
    "enabled": true,
  },
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enabled": false,
  },
  "tabs": {
    "git_status": true,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_status_icon": false,
    "show_branch_name": true,
  },
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "diagnostics": {
    "button": true,
  },
  "terminal": {
    "font_family": "Berkeley Mono",
    "dock": "bottom",
    "button": false,
  },
  "status_bar": {
    "show_active_file": false,
    "cursor_position_button": false,
    "active_language_button": true,
  },
  "project_panel": {
    "dock": "left",
    "button": true,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "proxy": "",
  "edit_predictions": {
    "mode": "subtle",
    "allow_data_collection": "no",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": true,
    "anthropic_retention": false,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 18.0,
  "theme": {
    "mode": "system",
    "light": "Nord Light",
    "dark": "GitHub Dark"
  },
}
